// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  GURU
  SISWA
}

enum QuestionType {
  PILGAN
  URAIAN
}

enum ExamStatus {
  ONGOING
  COMPLETED
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  name      String
  role             Role     @default(SISWA)
  jabatan          String?
  currentSessionId String?  // To track active login sessions
  createdAt        DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Guru can teach multiple subjects
  instructedMapels MataPelajaran[] @relation("GuruMapels")
  
  // Guru can create multiple modules
  modules Modul[]
  
  // Admin/Guru can create multiple exams
  ujians Ujian[]

  // Siswa belongs to a Rombel
  rombelId String?
  rombel   Rombel? @relation(fields: [rombelId], references: [id])

  // Results for Siswa
  hasilUjians HasilUjian[]
}

model Rombel {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Many users (Siswa) in one Rombel
  siswa User[]
  
  // Modules distributed to Rombel
  modules Modul[]
  
  // Exams scheduled for Rombel
  jadwalUjians JadwalUjian[]
}

model MataPelajaran {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Many guru can teach one subject (and vice versa)
  guru User[] @relation("GuruMapels")
}

model Modul {
  id        String   @id @default(uuid())
  title     String
  filePath  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Created by Guru
  guruId String
  guru   User   @relation(fields: [guruId], references: [id])

  // Distributed to Rombel
  rombelId String
  rombel   Rombel @relation(fields: [rombelId], references: [id])
}

model Ujian {
  id        String   @id @default(uuid())
  title     String
  mapel     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Created by Admin/Guru
  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  // Questions in this exam
  soals Soal[]

  // Schedules using this exam
  jadwalUjians JadwalUjian[]
}

model Soal {
  id           String       @id @default(uuid())
  questionType QuestionType @default(PILGAN)
  questionText String       @db.Text
  options      Json?        // Pilihan ganda options
  correctAnswer String?     // Kunci jawaban (for pilgan or manual grading reference)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Part of an Exam
  ujianId String
  ujian   Ujian @relation(fields: [ujianId], references: [id])
}

model JadwalUjian {
  id        String   @id @default(uuid())
  startTime DateTime
  endTime   DateTime
  deadline  DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Using a specific Ujian
  ujianId String
  ujian   Ujian @relation(fields: [ujianId], references: [id])

  // Assigned to a Rombel
  rombelId String
  rombel   Rombel @relation(fields: [rombelId], references: [id])

  // Results for this schedule
  hasilUjians HasilUjian[]
}

model HasilUjian {
  id          String     @id @default(uuid())
  score       Float      @default(0) // Deprecated total score
  scorePilgan Float      @default(0)
  scoreUraian Float      @default(0)
  answers     Json       // Siswa's answers
  status      ExamStatus @default(ONGOING)
  startTime   DateTime   @default(now())
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Siswa who took the exam
  siswaId String
  siswa   User   @relation(fields: [siswaId], references: [id])

  // Part of a specific schedule
  jadwalUjianId String
  jadwalUjian   JadwalUjian @relation(fields: [jadwalUjianId], references: [id])

  @@index([siswaId])
  @@index([jadwalUjianId])
}
